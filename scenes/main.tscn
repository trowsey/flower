[sub_resource type="Shader" id="Shader_1"]
code = "shader_type spatial;

uniform vec3 color_a : source_color = vec3(0.35, 0.5, 0.3);
uniform vec3 color_b : source_color = vec3(0.25, 0.38, 0.22);
uniform float tile_size = 2.0;

void fragment() {
	vec2 pos = (UV * 50.0) / tile_size;
	float checker = mod(floor(pos.x) + floor(pos.y), 2.0);
	ALBEDO = mix(color_a, color_b, checker);
}
"

